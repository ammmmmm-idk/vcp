# Copy this file to .env and fill in your real values.
VCP_SERVER_HOST=127.0.0.1
VCP_SERVER_BIND_HOST=0.0.0.0
VCP_SMTP_SERVER=smtp.gmail.com
VCP_SMTP_PORT=587
VCP_SENDER_EMAIL=your-email@gmail.com
VCP_SENDER_PASSWORD=your-app-password
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.4
GROQ_MAX_TOKENS=512
GROQ_CONTEXT_MESSAGES=12
TAVILY_API_KEY=your-tavily-api-key
TAVILY_MAX_RESULTS=3
